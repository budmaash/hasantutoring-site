---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const localBackendOrigin = 'http://localhost:5001';
---
<BaseLayout>
  <div id="siteWrapper" class="clearfix site-wrapper">
    <div id="floatingCart" class="floating-cart hidden">
      <a href="https://www.hasantutoring.com/cart" class="icon icon--stroke icon--fill icon--cart sqs-custom-cart">
        <span class="Cart-inner">
          <svg class="icon icon--cart" width="61" height="49" viewBox="0 0 61 49">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M0.5 2C0.5 1.17157 1.17157 0.5 2 0.5H13.6362C14.3878 0.5 15.0234 1.05632 15.123 1.80135L16.431 11.5916H59C59.5122 11.5916 59.989 11.8529 60.2645 12.2847C60.54 12.7165 60.5762 13.2591 60.3604 13.7236L50.182 35.632C49.9361 36.1614 49.4054 36.5 48.8217 36.5H18.0453C17.2937 36.5 16.6581 35.9437 16.5585 35.1987L12.3233 3.5H2C1.17157 3.5 0.5 2.82843 0.5 2ZM16.8319 14.5916L19.3582 33.5H47.8646L56.6491 14.5916H16.8319Z"></path>
            <path d="M18.589 35H49.7083L60 13H16L18.589 35Z"></path>
            <path d="M21 49C23.2091 49 25 47.2091 25 45C25 42.7909 23.2091 41 21 41C18.7909 41 17 42.7909 17 45C17 47.2091 18.7909 49 21 49Z"></path>
            <path d="M45 49C47.2091 49 49 47.2091 49 45C49 42.7909 47.2091 41 45 41C42.7909 41 41 42.7909 41 45C41 47.2091 42.7909 49 45 49Z"></path>
          </svg>
          <div class="legacy-cart icon-cart-quantity">
            <span class="sqs-cart-quantity">0</span>
          </div>
        </span>
      </a>
    </div>

    <SiteHeader />

    <main id="page" class="container apphome-webapp" role="main">
      <article class="sections" id="sections" data-page-sections="apphome-blank">
        <section class="card">
          <h2>Begin scoring</h2>
          <p>
            Choose the test you would like to score and enter the student's name and email. You'll enter the
            question responses on the next screen.
          </p>

          <form method="get" action={`${localBackendOrigin}/entry`} class="test-select-form" id="begin-scoring-form">
            <div class="form-field">
              <label for="test_id">Choose test</label>
              <select name="test_id" id="test_id" required>
                <option value="">Loading tests...</option>
              </select>
            </div>
            <div class="form-field">
              <label for="first_name">First name</label>
              <input type="text" name="first_name" id="first_name" placeholder="e.g. Jordan" value="" required />
            </div>
            <div class="form-field">
              <label for="last_name">Last name</label>
              <input type="text" name="last_name" id="last_name" placeholder="e.g. Lee" value="" required />
            </div>
            <div class="form-field">
              <label for="email">Email</label>
              <input type="email" name="email" id="email" placeholder="e.g. jordan.lee@example.com" value="" required />
            </div>
            <div class="form-actions">
              <div class="sqs-block" data-definition-name="website.components.button">
                <div class="sqs-block-content">
                  <div class="sqs-block-button-container sqs-block-button-container--left">
                    <div class="sqs-stretched">
                      <button type="submit" class="sqs-block-button-element">Start entering answers</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </form>
        </section>
      </article>
    </main>

    <SiteFooter />
  </div>

  <script is:inline defer="true" src="/Homepage_files/site-bundle.ffb22c3e841b638295ea13d0eb1a9f48.js" type="text/javascript"></script>
  <script is:inline>
    (function () {
      const testsApiCandidates = ['http://localhost:5001/api/tests'];
      const select = document.getElementById('test_id');
      if (!select) return;

      const renderOptions = (tests) => {
        select.innerHTML = '';
        if (!Array.isArray(tests) || tests.length === 0) {
          const option = document.createElement('option');
          option.value = '';
          option.textContent = 'No tests available';
          select.appendChild(option);
          select.disabled = true;
          return;
        }

        const placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.textContent = 'Select a test';
        placeholder.disabled = true;
        placeholder.selected = true;
        select.appendChild(placeholder);

        tests.forEach((test) => {
          const option = document.createElement('option');
          option.value = test.identifier || '';
          option.textContent = test.name || test.identifier || 'Untitled test';
          select.appendChild(option);
        });
      };

      const fetchFromCandidates = async () => {
        for (const url of testsApiCandidates) {
          try {
            const response = await fetch(url, { method: 'GET', mode: 'cors' });
            if (!response.ok) continue;
            const data = await response.json();
            if (Array.isArray(data)) return data;
          } catch (error) {
            // Try the next candidate endpoint.
          }
        }
        throw new Error('Failed to load tests from all API candidates');
      };

      fetchFromCandidates()
        .then((data) => renderOptions(data))
        .catch(() => {
          select.innerHTML = '';
          const option = document.createElement('option');
          option.value = '';
          option.textContent = 'Unable to load tests';
          select.appendChild(option);
          select.disabled = true;
        });
    })();
  </script>
  <style is:inline>
    .apphome-webapp {
      width: min(980px, 92vw);
      margin: 0 auto;
      padding: clamp(110px, 13vh, 170px) 0 3rem;
    }

    .apphome-webapp .card {
      background: #fff;
      border-radius: 1.25rem;
      padding: clamp(1.5rem, 4vw, 2.75rem);
      margin-bottom: 2rem;
      border: 1px solid #e2ddd3;
      box-shadow: 0 18px 45px rgba(17, 17, 17, 0.08);
    }

    .apphome-webapp .card h2,
    .apphome-webapp .card h3 {
      margin-top: 0;
      font-family: 'Playfair Display', 'Times New Roman', serif;
      font-weight: 600;
      letter-spacing: 0.05em;
    }

    .apphome-webapp .form-field {
      margin-bottom: 1.2rem;
      display: flex;
      flex-direction: column;
      min-width: 0;
    }

    .apphome-webapp .test-select-form {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem 1.25rem;
      align-items: end;
      margin-bottom: 1.5rem;
    }

    .apphome-webapp .form-field label {
      display: block;
      font-weight: 600;
      letter-spacing: 0.05em;
      margin-bottom: 0.4rem;
      color: #151515;
    }

    .apphome-webapp .form-field input[type='text'],
    .apphome-webapp .form-field input[type='email'],
    .apphome-webapp .form-field select {
      width: 100%;
      max-width: 100%;
      display: block;
      position: static;
      padding: 0.85rem 0.95rem;
      border-radius: 0.85rem;
      border: 1px solid #e2ddd3;
      box-sizing: border-box;
      background: #fbfaf7;
      color: inherit;
      font-size: 1rem;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .apphome-webapp .form-field input[type='text']:focus,
    .apphome-webapp .form-field input[type='email']:focus,
    .apphome-webapp .form-field select:focus {
      outline: none;
      border-color: #c6a764;
      box-shadow: 0 0 0 3px rgba(198, 167, 100, 0.25);
    }

    .apphome-webapp .form-field select {
      appearance: none;
      background-image: linear-gradient(45deg, transparent 50%, #5f5f5f 50%),
        linear-gradient(135deg, #5f5f5f 50%, transparent 50%);
      background-position: calc(100% - 18px) calc(50% - 4px), calc(100% - 12px) calc(50% - 4px);
      background-size: 6px 6px;
      background-repeat: no-repeat;
    }

    .apphome-webapp .form-actions {
      margin-top: 2rem;
      display: flex;
      justify-content: flex-start;
    }

    .apphome-webapp button,
    .apphome-webapp .button,
    .apphome-webapp .sqs-block-button-element {
      border: 1px solid #111;
      background: #111;
      color: #fff;
      padding: 0.85rem 2rem;
      border-radius: 999px;
      font-size: 0.95rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      cursor: pointer;
      transition: background 0.2s ease, transform 0.2s ease, color 0.2s ease;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      min-height: 50px;
    }

    .apphome-webapp button:hover,
    .apphome-webapp .button:hover,
    .apphome-webapp .sqs-block-button-element:hover {
      background: #333;
      color: #fff;
      text-decoration: none;
    }

    .apphome-webapp button:active,
    .apphome-webapp .button:active,
    .apphome-webapp .sqs-block-button-element:active {
      transform: translateY(1px);
    }

    @media (max-width: 960px) {
      .apphome-webapp .test-select-form {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .apphome-webapp .test-select-form {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
